#!/usr/bin/env bash
#
# ShareBoxx WiFi Access Point & Captive Portal Setup
#
# Configures a Linux machine (typically a Raspberry Pi) as a standalone open
# WiFi access point running ShareBoxx. It sets up:
#   - hostapd   (WiFi access point — open / passwordless by design)
#   - dnsmasq   (DHCP + DNS captive portal)
#   - shareboxx-ap.service (synchronous static IP on the AP interface)
#   - iptables  (HTTP redirect from :80 to ShareBoxx on :3000)
#   - shareboxx (systemd service — serves HTTP directly on :3000)
#
# ShareBoxx is HTTP-only by design. See README "Why no HTTPS?".
#
# Run as root after installing the shareboxx .deb package:
#   sudo shareboxx-setup            # configure or reconfigure
#   sudo shareboxx-setup --uninstall # revert all access-point config
#
set -euo pipefail

# ── CLI ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<USAGE
Usage: shareboxx-setup [--from-postinst] [--uninstall] [--help]

Without flags, runs the interactive access-point setup.

  --from-postinst   Skip apt-get install (the .deb's Depends already covers
                    runtime packages). Used by the package's postinst hook.
  --uninstall       Revert the access-point configuration: remove dhcpcd
                    block, dnsmasq config, hostapd config, iptables rules,
                    NetworkManager unmanage rule, and any legacy nginx site.
                    Does not remove the package, the binary, the user, or
                    files in /var/lib/shareboxx.
  --keep-config     Re-run setup without resetting the admin password or file
                    expiration settings. Skips the password / expiration
                    prompts if /var/lib/shareboxx/config.json already exists.
  -h, --help        Show this help.
USAGE
}

FROM_POSTINST=0
DO_UNINSTALL=0
KEEP_CONFIG=0
for arg in "$@"; do
    case "$arg" in
        --from-postinst) FROM_POSTINST=1 ;;
        --uninstall)     DO_UNINSTALL=1 ;;
        --keep-config)   KEEP_CONFIG=1 ;;
        -h|--help)       usage; exit 0 ;;
        *) echo "Unknown argument: $arg" >&2; usage >&2; exit 2 ;;
    esac
done
export KEEP_CONFIG

# ── Source shared library ───────────────────────────────────────────────────

SCRIPT_REAL_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
LIB_CANDIDATES=(
    "/usr/lib/shareboxx/setup-lib.sh"
    "$SCRIPT_REAL_DIR/setup-lib.sh"
)
SETUP_LIB_LOADED=0
for p in "${LIB_CANDIDATES[@]}"; do
    if [[ -f "$p" ]]; then
        # shellcheck disable=SC1090
        . "$p"
        SETUP_LIB_LOADED=1
        break
    fi
done
if [[ "$SETUP_LIB_LOADED" -ne 1 ]]; then
    echo "ERROR: cannot find setup-lib.sh in: ${LIB_CANDIDATES[*]}" >&2
    echo "       Reinstall the shareboxx package or run from the source tree." >&2
    exit 1
fi

print_logo

# ── Preflight ───────────────────────────────────────────────────────────────

if [[ $EUID -ne 0 ]]; then
    err "This script must be run as root (sudo shareboxx-setup)"
    exit 1
fi

if [[ $DO_UNINSTALL -eq 1 ]]; then
    do_uninstall
    info "Package, binary, shareboxx user, and /var/lib/shareboxx remain in place."
    info "To remove the package fully: sudo apt remove --purge shareboxx"
    exit 0
fi

if ! command -v shareboxx &>/dev/null; then
    warn "shareboxx binary not found in PATH."
    warn "Install the .deb package first: sudo dpkg -i shareboxx_*.deb"
    confirm "Continue anyway?" n || exit 1
fi

# ── Setup flow ──────────────────────────────────────────────────────────────

select_iface
check_ap_capability "$IFACE"
check_service_conflicts "$IFACE"
prompt_config
prompt_admin_config

# Install runtime packages (deb-specific). When invoked from postinst the
# .deb's Depends has already pulled them in.
if [[ $FROM_POSTINST -eq 1 ]]; then
    info "Skipping apt-get install — dependencies handled by .deb Depends."
else
    step "Installing system packages"
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y -qq dnsmasq hostapd iw iproute2 \
        netfilter-persistent iptables-persistent xxd
    ok "Packages installed"
fi

systemctl stop dnsmasq   2>/dev/null || true
systemctl stop hostapd   2>/dev/null || true
systemctl stop shareboxx 2>/dev/null || true
# Stop nginx if it was previously serving the legacy HTTPS site, so it
# releases port 3443; cleanup_legacy_https has already removed our site
# config but a running nginx may still hold the port until reload.
systemctl is-active --quiet nginx 2>/dev/null && systemctl reload nginx 2>/dev/null || true

cleanup_legacy_https
configure_ap_interface
configure_dnsmasq
configure_hostapd
configure_iptables_redirect
configure_cleanup_timer
write_config_json

start_services_and_check
print_summary

cat <<INFO

To reconfigure:  sudo shareboxx-setup
To revert:       sudo shareboxx-setup --uninstall
To check status: systemctl status shareboxx
INFO
